# Full Deriv affiliate / tracking URL (server-only). Used by GET /go — never commit real values.
DERIV_AFFILIATE_URL=https://example.com/your-affiliate-link

# Contact form → Gmail SMTP (free). You must use an App Password, not your normal Gmail password.
# Google Account → Security → 2-Step Verification → App passwords → Mail → copy the 16 characters.
# https://support.google.com/accounts/answer/185833
CONTACT_SMTP_USER=winroomderiv@gmail.com
CONTACT_SMTP_APP_PASSWORD=
# Optional: override the visible From (default = same mailbox with +site, helps Gmail Reply-To).
# CONTACT_SMTP_FROM_EMAIL=winroomderiv+site@gmail.com
# Optional: CONTACT_SMTP_HOST, CONTACT_SMTP_PORT if not using Gmail defaults.
# Plus-alias delivers to the same Gmail inbox but routes contact form mail more reliably than To=From.
CONTACT_TO_EMAIL=winroomderiv+inbox@gmail.com

# Admin upload (/videos/upload): password login + signed session cookie
ADMIN_PASSWORD=change-me-to-a-long-random-secret
ADMIN_SESSION_SECRET=change-me-to-another-long-random-secret

# Bunny Stream (server-only): library numeric ID + Stream API key from Bunny dashboard
# Used to list playable videos for the homepage and to create / presign TUS uploads.
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=

# Optional: public-facing brand (defaults to "Win Room" if unset)
# NEXT_PUBLIC_SITE_NAME=Win Room
# NEXT_PUBLIC_SITE_TAGLINE=Video strategy lab · Members unlock the full library

# --- Member video library (optional) ---
# If MEMBER_ACCESS_CODE (or MEMBER_ACCESS_CODES) and VIDEO_GATE_SECRET are set, lesson embeds are
# hidden until the user visits /go (affiliate click cookie) and enters the code on /unlock.
# Share codes only with people you confirm in your Deriv partner dashboard (Deriv does not POST to this site).
VIDEO_GATE_SECRET=generate-a-long-random-string
MEMBER_ACCESS_CODE=your-secret-passphrase-for-members
# Or multiple codes (comma-separated): MEMBER_ACCESS_CODE=code1,code2
# Optional: set "true" to require the user to open /go in the SAME browser before unlock (stricter; breaks if they switch devices)
# REQUIRE_AFFILIATE_CLICK_BEFORE_UNLOCK=false
